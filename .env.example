# Seichijunrei — Environment Variables
# Copy to .env and fill in your values.

# ============================================================
# REQUIRED
# ============================================================

# Supabase — direct Postgres connection (asyncpg)
SUPABASE_DB_URL=postgresql://postgres.your-project:password@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here

# Anitabi API (external data source, default is public endpoint)
ANITABI_API_URL=https://api.anitabi.cn/bangumi

# Google / Gemini — pydantic-ai LLM backend
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================================
# OPTIONAL — Application tuning
# ============================================================

APP_ENV=development
LOG_LEVEL=INFO
DEBUG=false
MAX_RETRIES=3
TIMEOUT_SECONDS=30
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8080

CACHE_TTL_SECONDS=3600
USE_CACHE=true

RATE_LIMIT_CALLS=100
RATE_LIMIT_PERIOD_SECONDS=60

# ============================================================
# OPTIONAL — Observability (OpenTelemetry)
# ============================================================

OBSERVABILITY_ENABLED=false
OBSERVABILITY_EXPORTER_TYPE=none   # none | console | otlp
# OBSERVABILITY_OTLP_ENDPOINT=http://localhost:4317
