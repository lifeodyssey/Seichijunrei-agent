# Test environment variables
# Copy this file to .env.test and fill in your values.
# NEVER commit .env.test — it contains secrets.

# Supabase project (same as production — test user is isolated by RLS)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# QA test user (created via Supabase Dashboard > Auth > Users > Add user)
# This user is used by automated tests and headless browser QA.
# Create with "Auto Confirm" enabled. Email does not need to be real.
QA_USER_EMAIL=qa@test

# Site URL for browser QA
QA_SITE_URL=https://seichijunrei.zhenjiazhou0127.workers.dev
